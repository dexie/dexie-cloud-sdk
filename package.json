{
  "name": "dexie-cloud-sdk",
  "version": "0.1.0",
  "description": "Official JavaScript SDK for Dexie Cloud",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external node-fetch",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:unit": "vitest tests/unit --run",
    "test:integration": "vitest tests/integration --run",
    "test:integration:local": "./scripts/test-integration-local.sh",
    "test:all": "npm run test:unit && npm run test:integration:local",
    "type-check": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts,.js --fix",
    "prepublishOnly": "npm run build && npm run test:unit",
    "release": "npm version patch && npm publish && git push --follow-tags"
  },
  "keywords": [
    "dexie",
    "dexie-cloud", 
    "indexeddb",
    "local-first",
    "sync",
    "offline",
    "database",
    "cloud",
    "rest",
    "api",
    "client"
  ],
  "author": "Dexie Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dexie/dexie-cloud-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/dexie/dexie-cloud-sdk/issues"
  },
  "homepage": "https://dexie.org/cloud",
  "peerDependencies": {
    "dreambase-library": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "dreambase-library": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "node-fetch": "^3.3.2",
    "tsup": "^8.0.0",
    "typescript": "^5.2.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {}
}